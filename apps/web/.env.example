# App Configuration
NEXT_PUBLIC_APP_URL=https://decebaldobrica.com

# Groq AI (Required for chat)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Calendar (Required for meeting scheduling)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://decebaldobrica.com/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=your_refresh_token
CALENDAR_OWNER_EMAIL=decebal@dobrica.dev

# Email - Resend (Required for meeting confirmations)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@decebaldobrica.com
EMAIL_REPLY_TO=decebal@dobrica.dev

# AllSource (event store replacing Supabase for all persistence)
# API URL is the public query-service front door; tenant + key identify the account.
# The service-account API key is a tenant-scoped JWT sent as the X-API-Key header.
ALLSOURCE_API_URL=https://allsource-query.fly.dev
ALLSOURCE_TENANT_ID=your-tenant-id
ALLSOURCE_API_KEY=your_allsource_service_account_api_key

# Solana Pay (Required for crypto payments)
NEXT_PUBLIC_SOLANA_MERCHANT_ADDRESS=your_solana_wallet_address
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet  # Use 'mainnet-beta' for production

# Analytics - PostHog (Optional)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# Set to "true" to disable PostHog (client + server). Useful for local dev.
NEXT_PUBLIC_POSTHOG_DISABLED=false

# Bot Protection - Cloudflare Turnstile (Optional, recommended for production)
# Get your keys at https://dash.cloudflare.com/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Feature Flags
NEXT_PUBLIC_ENABLE_PAID_MEETINGS=false  # Show paid meeting types (30min, 60min, 90min)
NEXT_PUBLIC_ENABLE_HOMEPAGE_VIDEO=false  # Show video player on homepage (false = static image only)
NEXT_PUBLIC_ENABLE_WALLET_PAYMENTS=false  # Enable wallet-based payment gating on services page
NEXT_PUBLIC_PREMIUM_SUBSCRIPTIONS_ENABLED=false  # Enable premium newsletter subscription payments (false = show interest modal)
NEXT_PUBLIC_FOUNDING_MEMBER_ENABLED=false  # Enable founding member subscription payments (false = show interest modal)
