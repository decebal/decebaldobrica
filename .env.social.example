# ──────────────────────────────────────────────────────────────────────────
# Social posting credentials for `task publish`
# Copy the values you obtain (see docs/SOCIAL_POSTING_SETUP.md) into your real,
# gitignored `.env` at the repo root. Do NOT commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# ── Twitter / X (OAuth 1.0a user context — needed to post on your behalf) ──
# From https://developer.x.com → your Project → App. The App's "User
# authentication settings" MUST be set to Read and Write BEFORE you generate
# the Access Token/Secret (otherwise regenerate them after enabling write).
TWITTER_API_KEY=            # "API Key" (a.k.a. Consumer Key)
TWITTER_API_SECRET=         # "API Key Secret" (a.k.a. Consumer Secret)
TWITTER_ACCESS_TOKEN=       # "Access Token" (user context)
TWITTER_ACCESS_SECRET=      # "Access Token Secret"

# ── LinkedIn (OAuth 2.0; posts via UGC Posts API with w_member_social) ──
# From https://www.linkedin.com/developers/apps → your App.
# Add the "Share on LinkedIn" product to get the w_member_social scope, then
# run the OAuth flow to mint a token. Token lasts ~60 days (refresh ~365 days).
LINKEDIN_ACCESS_TOKEN=      # OAuth2 access token with w_member_social + profile/openid
LINKEDIN_PERSON_URN=        # e.g. urn:li:person:AbC123  (from /v2/userinfo "sub")

# Only needed if you use refreshLinkedInToken() to auto-refresh the access token:
LINKEDIN_CLIENT_ID=         # App "Client ID"
LINKEDIN_CLIENT_SECRET=     # App "Client Secret"
